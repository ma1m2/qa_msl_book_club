{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PaginatedClubList",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "count": { "type": "integer" },
    "next": { "type": ["string", "null"], "format": "uri" },
    "previous": { "type": ["string", "null"], "format": "uri" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "integer" },
          "bookTitle": { "type": "string" },
          "bookAuthors": { "type": "string" },
          "publicationYear": { "type": "integer" },
          "description": { "type": "string" },
          "telegramChatLink": { "type": "string", "format": "uri" },
          "owner": { "type": "integer" },
          "members": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "reviews": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "id": { "type": "integer" },
                "club": { "type": "integer" },
                "user": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "id": { "type": "integer" },
                    "username": { "type": "string" }
                  },
                  "required": ["id", "username"]
                },
                "review": { "type": "string" },
                "assessment": { "type": "integer", "minimum": 1, "maximum": 5 },
                "readPages": { "type": "integer" },
                "created": { "type": "string", "format": "date-time" },
                "modified": { "type": ["string", "null"], "format": "date-time" }
              },
              "required": [
                "id",
                "club",
                "user",
                "review",
                "assessment",
                "readPages",
                "created",
                "modified"
              ]
            }
          },
          "created": { "type": "string", "format": "date-time" },
          "modified": { "type": ["string", "null"], "format": "date-time" }
        },
        "required": [
          "id",
          "bookTitle",
          "bookAuthors",
          "publicationYear",
          "description",
          "telegramChatLink",
          "owner",
          "members",
          "reviews",
          "created",
          "modified"
        ]
      }
    }
  },
  "required": ["count", "results"]
}

