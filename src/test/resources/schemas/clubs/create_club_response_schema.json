{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreateClubResponse",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": { "type": "integer" },
    "bookTitle": { "type": "string" },
    "bookAuthors": { "type": "string" },
    "publicationYear": { "type": "integer" },
    "description": { "type": "string" },
    "telegramChatLink": { "type": "string", "format": "uri" },
    "owner": { "type": "integer" },
    "members": {
      "type": "array",
      "items": { "type": "integer" }
    },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "created": { "type": "string", "format": "date-time" },
    "modified": { "type": ["string", "null"], "format": "date-time" }
  },
  "required": [
    "id",
    "bookTitle",
    "bookAuthors",
    "publicationYear",
    "description",
    "telegramChatLink",
    "owner",
    "members",
    "reviews",
    "created",
    "modified"
  ]
}
